{
  "name": "rmk-gui",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:web": "vite",
    "dev:tauri": "tauri dev",
    "build:web": "vite build",
    "build:tauri": "tauri build",
    "build:wasm": "nu scripts/build-rynk-wasm.nu",
    "postinstall": "pnpm run build:wasm",
    "qemu": "node qemu/run.mjs",
    "generate": "vite build",
    "preview": "vite preview",
    "lint": "run-s lint:ts lint:rs",
    "lint:ts": "eslint .",
    "lint:rs": "cd src-tauri && cargo clippy --all-targets -- -D warnings",
    "lint:fix": "run-s lint:fix:ts lint:fix:rs",
    "lint:fix:ts": "eslint . --fix",
    "lint:fix:rs": "cd src-tauri && cargo fmt",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iconify-icon/solid": "^3.0.3",
    "@tauri-apps/api": "^2.11.1",
    "neverthrow": "^8.2.0",
    "solid-js": "^1.9.14",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify-json/lucide": "^1.2.117",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/w3c-web-serial": "^1.0.8",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-solid": "^0.14.5",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12"
  }
}
